{
  "openapi": "3.0.4",
  "info": {
    "title": "Flying Daggers API",
    "description": "Flying Daggers API management",
    "version": "1.0.0"
  },
  "paths": {
    "/api/Authentication/login": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDetails"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDetails"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/LoginDetails"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/Authentication/register": {
      "post": {
        "tags": [
          "Authentication"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/RegisterResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegisterResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegisterResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error"
          }
        }
      }
    },
    "/api/Battle/start": {
      "post": {
        "tags": [
          "Battle"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/BattleRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/BattleRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/BattleRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/BattleResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/BattleResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/BattleResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/api/FlyingShadow/Shadows": {
      "get": {
        "tags": [
          "FlyingShadow"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/ShadowDto"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AcrobaticsLevel": {
        "type": "integer"
      },
      "BattleRequest": {
        "required": [
          "shadowOneCodeName",
          "shadowTwoCodeName"
        ],
        "type": "object",
        "properties": {
          "shadowOneCodeName": {
            "type": "string"
          },
          "shadowTwoCodeName": {
            "type": "string"
          }
        }
      },
      "BattleResponse": {
        "required": [
          "outcome",
          "shadowOneStats",
          "shadowTwoStats",
          "statBreakdown"
        ],
        "type": "object",
        "properties": {
          "outcome": {
            "type": "string"
          },
          "shadowOneStats": {
            "$ref": "#/components/schemas/Stats"
          },
          "shadowTwoStats": {
            "$ref": "#/components/schemas/Stats"
          },
          "statBreakdown": {
            "$ref": "#/components/schemas/StatResults"
          }
        }
      },
      "Error": {
        "required": [
          "code",
          "message"
        ],
        "type": "object",
        "properties": {
          "code": {
            "$ref": "#/components/schemas/ErrorCode"
          },
          "message": {
            "type": "string"
          }
        }
      },
      "ErrorCode": {
        "type": "integer"
      },
      "LoginDetails": {
        "required": [
          "email",
          "password"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "LoginResponse": {
        "required": [
          "tokenDetails"
        ],
        "type": "object",
        "properties": {
          "tokenDetails": {
            "$ref": "#/components/schemas/TokenDetails"
          }
        }
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "nullable": true
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "format": "int32",
            "nullable": true
          },
          "detail": {
            "type": "string",
            "nullable": true
          },
          "instance": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "Rank": {
        "type": "integer"
      },
      "RegisterRequest": {
        "required": [
          "email",
          "password"
        ],
        "type": "object",
        "properties": {
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "RegisterResponse": {
        "required": [
          "userId"
        ],
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "ShadowDto": {
        "required": [
          "id",
          "codeName",
          "clan",
          "origin",
          "rank",
          "shadowSkills"
        ],
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "codeName": {
            "type": "string"
          },
          "clan": {
            "type": "string"
          },
          "origin": {
            "type": "string"
          },
          "rank": {
            "$ref": "#/components/schemas/Rank"
          },
          "shadowSkills": {
            "$ref": "#/components/schemas/StealthMetricsDto"
          }
        }
      },
      "StatResults": {
        "required": [
          "combatPowerWinner",
          "evasionIndexWinner",
          "stealthScoreWinner"
        ],
        "type": "object",
        "properties": {
          "combatPowerWinner": {
            "type": "string"
          },
          "evasionIndexWinner": {
            "type": "string"
          },
          "stealthScoreWinner": {
            "type": "string"
          }
        }
      },
      "Stats": {
        "required": [
          "codeName",
          "combatPower",
          "evasionIndex",
          "stealthScore",
          "overallRating"
        ],
        "type": "object",
        "properties": {
          "codeName": {
            "type": "string"
          },
          "combatPower": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "format": "double"
          },
          "evasionIndex": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "format": "double"
          },
          "stealthScore": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "format": "double"
          },
          "overallRating": {
            "pattern": "^-?(?:0|[1-9]\\d*)(?:\\.\\d+)?$",
            "format": "double"
          }
        }
      },
      "StealthMetricsDto": {
        "type": "object",
        "properties": {
          "shadowBlendScore": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "format": "int32"
          },
          "silenceRating": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "format": "int32"
          },
          "invisibilityDurationMs": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "format": "int32"
          },
          "acrobaticsLevel": {
            "$ref": "#/components/schemas/AcrobaticsLevel"
          }
        }
      },
      "TokenDetails": {
        "required": [
          "token",
          "expiresAt"
        ],
        "type": "object",
        "properties": {
          "token": {
            "type": "string"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Authentication"
    },
    {
      "name": "Battle"
    },
    {
      "name": "FlyingShadow"
    }
  ]
}